function openDetail(id) {
  const r = roles[id];
  if (!r) return;
  document.getElementById('d-faction').textContent = r.faction;
  document.getElementById('d-faction').style.color = r.color;
  document.getElementById('d-emoji').textContent = r.emoji;
  document.getElementById('d-name').textContent = r.name;
  document.getElementById('d-analog').textContent = r.analog;
  const action = document.getElementById('d-action');
  action.textContent = r.action;
  action.style.background = r.color + '22';
  action.style.color = r.color;
  document.getElementById('d-desc').textContent = r.desc;
  document.getElementById('d-win').textContent = r.win;
  document.getElementById('d-tip').textContent = r.tip;
  document.getElementById('detail-modal').classList.add('open');
}

function closeDetail(e) {
  if (!e || e.target === document.getElementById('detail-modal') || e.currentTarget?.classList?.contains('detail-close')) {
    document.getElementById('detail-modal').classList.remove('open');
  }
}

function filter(type, btn) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.card').forEach(card => {
    if (type === 'all' || card.classList.contains(type)) {
      card.classList.add('visible');
    } else {
      card.classList.remove('visible');
    }
  });
}

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') document.getElementById('detail-modal').classList.remove('open');
});
